# =====================
# administration/models.py - Link
# =====================

msgid "Link"
msgstr "Enlace"

msgid "Links"
msgstr "Enlaces"

msgid "display name"
msgstr "nombre de visualización"

msgid "popup description"
msgstr "descripción del popup"

msgid "curvature"
msgstr "curvatura"

msgid "This field controls how curved the link will appear in the front-end. The higher the number, the less the link will be curved. Min(1)-Max(4). Accept decimal values."
msgstr "Este campo controla la curvatura del enlace en el front-end. Cuanto mayor sea el número, menos curvado será el enlace. Mín(1)-Máx(4). Acepta valores decimales."

msgid "weight"
msgstr "peso"

msgid "This field controls the weight of the link line. The higher the number, the wider the line."
msgstr "Este campo controla el grosor de la línea del enlace. Cuanto mayor sea el número, más ancha será la línea."

msgid "dashed"
msgstr "punteado"

msgid "This field, when active, will make the link stroke dashed."
msgstr "Este campo, cuando está activo, hará que el trazo del enlace sea punteado."

msgid "straight link"
msgstr "enlace recto"

msgid "This field, when active, will make the link line straight."
msgstr "Este campo, cuando está activo, hará que la línea del enlace sea recta."

msgid "location 1"
msgstr "ubicación 1"

msgid "location 2"
msgstr "ubicación 2"

msgid "links group"
msgstr "grupo de enlaces"

msgid "invert link"
msgstr "invertir enlace"

msgid "This field, when active, will invert the curvature of the link."
msgstr "Este campo, cuando está activo, invertirá la curvatura del enlace."

# =====================
# administration/models.py - Map_configuration
# =====================

msgid "Map Settings"
msgstr "Configuración del Mapa"

msgid "map name"
msgstr "nombre del mapa"

msgid "map style"
msgstr "estilo del mapa"

msgid "Default (gray colored)"
msgstr "Predeterminado (gris)"

msgid "Blue colored"
msgstr "Azul"

msgid "inherit children tag locations"
msgstr "heredar ubicaciones de etiquetas hijas"

msgid "When this field is enabled, a tag that is parent from another tags will inherit all locations from the children that was not previously declared on the parent. If instead you want to manually declare the locations for all tags, we suggest to keep this field disabled."
msgstr "Cuando este campo está habilitado, una etiqueta que es padre de otras etiquetas heredará todas las ubicaciones de los hijos que no fueron previamente declaradas en el padre. Si desea declarar manualmente las ubicaciones para todas las etiquetas, le sugerimos mantener este campo deshabilitado."

msgid "cluster close tags"
msgstr "agrupar etiquetas cercanas"

msgid "When this field is enabled, tags located very close to each other will be grouped in clusters."
msgstr "Cuando este campo está habilitado, las etiquetas ubicadas muy cerca unas de otras se agruparán en clústeres."

msgid "initial zoom level"
msgstr "nivel de zoom inicial"

msgid "Please insert a value from 0 to 13 (max zoom)."
msgstr "Por favor, inserte un valor de 0 a 13 (zoom máximo)."

msgid "initial latitude"
msgstr "latitud inicial"

msgid "initial longitude"
msgstr "longitud inicial"

msgid "link feature"
msgstr "función de enlace"

msgid "When this field is enabled, the link feature will be displayed on the front-end."
msgstr "Cuando este campo está habilitado, la función de enlace se mostrará en el front-end."

msgid "hide menu group when unique"
msgstr "ocultar grupo de menú cuando es único"

msgid "When there is only one Menu Group active, hide the menu groups tabs"
msgstr "Cuando solo hay un Grupo de Menú activo, ocultar las pestañas de grupos de menú"

msgid "footer file"
msgstr "archivo de pie de página"

msgid "Upload a custom footer file."
msgstr "Suba un archivo de pie de página personalizado."

