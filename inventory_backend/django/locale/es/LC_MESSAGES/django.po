# =====================
# administration/models.py - Tag_relationship
# =====================

msgid "Tag to tag relation"
msgstr "Relación entre etiquetas"

msgid "Tag to tag relationships"
msgstr "Relaciones entre etiquetas"

msgid "child tag"
msgstr "etiqueta hija"

msgid "parent tag"
msgstr "etiqueta padre"

msgid "cluster ID"
msgstr "ID del clúster"

msgid "Tag clusters are group of parent tags from the tag. To a cluster id be active, all tags in that id must be active. The child tag will be active if at least one of the cluster ids is active."
msgstr "Los clústeres de etiquetas son grupos de etiquetas padre de la etiqueta. Para que un ID de clúster esté activo, todas las etiquetas en ese ID deben estar activas. La etiqueta hija estará activa si al menos uno de los IDs de clúster está activo."

