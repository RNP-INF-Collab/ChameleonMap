# =====================

msgid "Tag to tag relation"
msgstr "Relação entre tags"

msgid "Tag to tag relationships"
msgstr "Relações entre tags"

msgid "child tag"
msgstr "tag filha"

msgid "parent tag"
msgstr "tag pai"

msgid "cluster ID"
msgstr "ID do cluster"

msgid "Tag clusters are group of parent tags from the tag. To a cluster id be active, all tags in that id must be active. The child tag will be active if at least one of the cluster ids is active."
msgstr "Clusters de tags são grupos de tags pai da tag. Para que um ID de cluster esteja ativo, todas as tags naquele ID devem estar ativas. A tag filha estará ativa se pelo menos um dos IDs de cluster estiver ativo."

