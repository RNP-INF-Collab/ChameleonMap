# =====================
# administration/models.py - Link
# =====================

msgid "Link"
msgstr "Link"

msgid "Links"
msgstr "Links"

msgid "display name"
msgstr "nome de exibição"

msgid "popup description"
msgstr "descrição do popup"

msgid "curvature"
msgstr "curvatura"

msgid "This field controls how curved the link will appear in the front-end. The higher the number, the less the link will be curved. Min(1)-Max(4). Accept decimal values."
msgstr "Este campo controla a curvatura do link no front-end. Quanto maior o número, menos curvado será o link. Mín(1)-Máx(4). Aceita valores decimais."

msgid "weight"
msgstr "espessura"

msgid "This field controls the weight of the link line. The higher the number, the wider the line."
msgstr "Este campo controla a espessura da linha do link. Quanto maior o número, mais larga será a linha."

msgid "dashed"
msgstr "tracejado"

msgid "This field, when active, will make the link stroke dashed."
msgstr "Este campo, quando ativo, tornará o traço do link tracejado."

msgid "straight link"
msgstr "link reto"

msgid "This field, when active, will make the link line straight."
msgstr "Este campo, quando ativo, tornará a linha do link reta."

msgid "location 1"
msgstr "local 1"

msgid "location 2"
msgstr "local 2"

msgid "links group"
msgstr "grupo de links"

msgid "invert link"
msgstr "inverter curvatura"

msgid "This field, when active, will invert the curvature of the link."
msgstr "Este campo, quando ativo, inverterá a curvatura do link."

# =====================
# administration/models.py - Map_configuration
# =====================

msgid "Map Settings"
msgstr "Configurações do Mapa"

msgid "map name"
msgstr "nome do mapa"

msgid "map style"
msgstr "estilo do mapa"

msgid "Default (gray colored)"
msgstr "Padrão (cinza)"

msgid "Blue colored"
msgstr "Azul"

msgid "inherit children tag locations"
msgstr "herdar locais das tags filhas"

msgid "When this field is enabled, a tag that is parent from another tags will inherit all locations from the children that was not previously declared on the parent. If instead you want to manually declare the locations for all tags, we suggest to keep this field disabled."
msgstr "Quando este campo está habilitado, uma tag que é pai de outras tags herdará todos os locais dos filhos que não foram previamente declarados no pai. Se, em vez disso, você deseja declarar manualmente os locais para todas as tags, sugerimos manter este campo desabilitado."

msgid "cluster close tags"
msgstr "agrupar tags próximas"

msgid "When this field is enabled, tags located very close to each other will be grouped in clusters."
msgstr "Quando este campo está habilitado, tags localizadas muito próximas umas das outras serão agrupadas em clusters."

msgid "initial zoom level"
msgstr "nível de zoom inicial"

msgid "Please insert a value from 0 to 13 (max zoom)."
msgstr "Por favor, insira um valor de 0 a 13 (zoom máximo)."

msgid "initial latitude"
msgstr "latitude inicial"

msgid "initial longitude"
msgstr "longitude inicial"

msgid "link feature"
msgstr "funcionalidade de links"

msgid "When this field is enabled, the link feature will be displayed on the front-end."
msgstr "Quando este campo está habilitado, o recurso de link será exibido no front-end."

msgid "hide menu group when unique"
msgstr "ocultar grupo de menu quando único"

msgid "When there is only one Menu Group active, hide the menu groups tabs"
msgstr "Quando há apenas um Grupo de Menu ativo, ocultar as abas dos grupos de menu"

msgid "footer file"
msgstr "arquivo de rodapé"

msgid "Upload a custom footer file."
msgstr "Carregue um arquivo de rodapé personalizado."

